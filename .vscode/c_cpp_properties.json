{
    "configurations": [
        {
            "name": "XC16",
            "includePath": [
                "${workspaceFolder}",
                "${workspaceFolder}/FreeRTOS/Source/include",
                "${workspaceFolder}/FreeRTOS/Source/portable/MPLAB/PIC24_dsPIC",
                "/Applications/microchip/xc16/v2.10/support/generic/h",
                "/Applications/microchip/xc16/v2.10/support/PIC24E/h",
                "/Applications/microchip/xc16/v2.10/include",
                "${env:HOME}/.mchp_packs/Microchip/dsPIC33E-GM-GP-MC-GU-MU_DFP/1.6.297/xc16/support/PIC24E/h"
            ],
            "compilerPath": "/Applications/microchip/xc16/v2.10/bin/xc16-gcc",
            "defines": [
                "__XC16__",
                "__XC16",
                "__PIC24EP256MC206__",
                "__24EP256MC206__",
                "__PIC24E__",
                "XPRJ_default=default"
            ],
            "intelliSenseMode": "gcc-x86",
            "cStandard": "gnu99"
        }
    ],
    "version": 4
